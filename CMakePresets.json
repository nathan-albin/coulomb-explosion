{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 20,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "binaryDir": "${sourceDir}/build/${presetName}",
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "debug",
      "displayName": "Debug (warnings + sanitizers)",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "COULOMB_ENABLE_SANITIZERS": "ON",
        "COULOMB_BUILD_TESTS": "ON"
      }
    },
    {
      "name": "release",
      "displayName": "Release (optimized)",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "COULOMB_BUILD_TESTS": "ON"
      }
    },
    {
      "name": "relwithdebinfo",
      "displayName": "RelWithDebInfo + benchmarks",
      "inherits": "release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "COULOMB_BUILD_BENCHMARKS": "ON"
      }
    },
    {
      "name": "relwithdebinfo-f32",
      "displayName": "RelWithDebInfo + benchmarks, single precision (Real=float)",
      "inherits": "relwithdebinfo",
      "cacheVariables": {
        "COULOMB_SINGLE_PRECISION": "ON"
      }
    }
  ],
  "buildPresets": [
    { "name": "debug",   "configurePreset": "debug" },
    { "name": "release", "configurePreset": "release" },
    { "name": "relwithdebinfo", "configurePreset": "relwithdebinfo" },
    { "name": "relwithdebinfo-f32", "configurePreset": "relwithdebinfo-f32" }
  ],
  "testPresets": [
    {
      "name": "debug",
      "configurePreset": "debug",
      "output": { "outputOnFailure": true }
    },
    {
      "name": "release",
      "configurePreset": "release",
      "output": { "outputOnFailure": true }
    }
  ]
}
